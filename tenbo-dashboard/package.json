  "description": "Local-first architecture dashboard and CLI tools for .tenbo/ repos",
  "type": "module",
  "license": "MIT",
  "author": "Po-Yi Chen",
  "repository": {
    "type": "git",
    "url": "https://github.com/poyi/tenbo.git",
