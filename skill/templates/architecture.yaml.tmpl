# .tenbo/scopes/<scope>/architecture.yaml — generated by the tenbo skill.
# Lists the architecture layers within this scope, in plain language.
#
# Rules:
#   - 5 to 10 top-level layers per scope.
#   - `description` is mandatory and must be readable by a non-engineer.
#   - `files` is for the agent's benefit; never shown to non-engineers.
#   - Optional `parent` field promotes a layer into a sub-layer (depth 2 max).

layers:
  - id: example-layer
    name: "Example Layer"
    description: "<one sentence: what this layer is for, in non-engineer terms>"
    files: ["src/example/**"]

  # Opt-in sub-layer; uncomment and edit only when warranted.
  # - id: example-layer.subconcern
  #   parent: example-layer
  #   name: "Example Sub-concern"
  #   description: "<one sentence>"
  #   files: ["src/example/subconcern/**"]
