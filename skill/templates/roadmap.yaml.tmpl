# .tenbo/scopes/<scope>/roadmap.yaml — generated by the tenbo skill.
# Roadmap items, each tagged to a layer.
#
# Status values: now | next | later | done | dropped
#   - now:     in active progress this session
#   - next:    queued for the next iteration
#   - later:   captured but not yet scheduled
#   - done:    work shipped (set `doc_update:` for feature/bug/refactor types)
#   - dropped: explicitly will not be completed (superseded, deprioritized
#              indefinitely, or scoped out). Distinct from `done` (the work
#              shipped) and `later` (still in the queue).
# `id` format: <prefix>-NNN where <prefix> is the scope's prefix from workspace.yaml
#   (1–5 lowercase letters, e.g. `ed-001` for editor scope, `ui-001` for ui scope).
#   NNN is zero-padded and monotonically increases within the scope.
# Cross-scope items use prefix `x` (e.g. `x-001`).
# `description` is mandatory.

items: []

# Example item (uncomment to see the shape):
# items:
#   - id: ed-001
#     title: "Example feature"
#     layer: example-layer
#     status: later
#     description: "<one sentence describing the feature in non-engineer terms>"
#
# Cross-scope item (rare):
#   - id: x-001
#     title: "Cross-scope rename"
#     layers: [scope-a.layer-x, scope-b.layer-y]
#     status: later
#     description: "<one sentence>"
#
# Multi-phase item (optional `phases:` field):
#   When phases are present, the item-level `status` is *derived* from the
#   phases — drop the explicit `status:` line. Roll-up rule:
#     - done   if every phase is done
#     - now    if any phase is now
#     - else next  if any phase is next
#     - else later
#   Each phase needs `id` (1..N matching position), `title`, and `status`.
#   `completed_at` (YYYY-MM-DD) is set when status flips to `done`.
#   `notes` is optional freeform per-phase markdown.
#
#   - id: ed-050
#     title: "Frames architecture"
#     layer: visual-canvas
#     description: "Multi-frame canvas + cross-frame AI tools."
#     phases:
#       - id: 1
#         title: "Data model + migration"
#         status: done
#         completed_at: 2026-04-27
#       - id: 2
#         title: "Multi-frame UI"
#         status: now
#       - id: 3
#         title: "AI cross-frame tools"
#         status: later
#       - id: 4
#         title: "Polish"
#         status: later
#
# Relationships (optional `spawned_from:` and `related:` fields):
#   `spawned_from` is a single roadmap-item id (at most one parent — the item that
#   surfaced this work). `related` is a list of peer ids (any number; not parent–child).
#   Both are optional. Both are validated:
#     - id format must match `<prefix>-NNN` or `x-NNN`.
#     - referenced id missing from the workspace → warning (not error: the parent or
#       peer may legitimately be tracked before referenced items are created).
#     - self-reference (id equals the item's own id) → error.
#     - duplicate id within `related` → warning.
#     - same id in both `spawned_from` and `related` → warning (redundant).
#   Convention (Behavior 5 DoD): when a subagent's report surfaces a follow-up item,
#   the new item should set `spawned_from` to the dispatching item's id, so the
#   parent → child trail isn't buried in `notes:` prose.
#
#   - id: ed-060
#     title: "Follow-up surfaced by ed-049 dispatch"
#     layer: visual-canvas
#     status: next
#     description: "<one sentence>"
#     spawned_from: ed-049
#     related: [ed-046, ed-057]
#
# Supersession (optional `superseded_by:` field):
#   When work is replaced by a different item, mark the old item `dropped` and
#   set `superseded_by:` to the replacing item's id. Validator enforces:
#     - superseded item must have status `dropped`.
#     - referenced id must exist and have valid format.
#     - no cycles (A superseded_by B, B superseded_by A).
#     - warning if the superseder is still in next/now (confirm it's real).
#   The Health system surfaces `later` items that reference done/dropped items
#   via this field (or spawned_from/related) as stale candidates for triage.
#
#   - id: ed-040
#     title: "Old approach to caching"
#     layer: data-layer
#     status: dropped
#     description: "<one sentence>"
#     superseded_by: ed-065
