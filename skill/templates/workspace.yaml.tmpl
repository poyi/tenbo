# .tenbo/workspace.yaml — generated by the tenbo skill.
# Lists the top-level "scopes" of this repo. For a single-app repo, one scope `root`.
# For monorepos, one scope per app/package.

# Auto-managed project maturity. Values: new | early | active | mature
# - new:    repo has <5 source files or no source directory
# - early:  source exists but tenbo was just set up (no intent.md populated yet)
# - active: at least one layer has populated architecture docs
# - mature: all layers have populated docs, >50% of roadmap items completed
maturity: early

# Session counter for progressive disclosure. Bumped on each session-init read.
tenbo_sessions: 0

scopes:
  - id: root
    prefix: ro              # 1–5 lowercase letters; auto-derived from `id` during bootstrap
    path: .
    description: "<one sentence: what this app/repo is for, in non-engineer terms>"

# Optional: concerns that span multiple scopes (e.g., shared design tokens).
# Remove this section if not needed.
cross_cutting: []
# cross_cutting:
#   - id: design-tokens
#     description: "Color/spacing/typography vocabulary used everywhere."
#     spans: [scope-id-a, scope-id-b]
